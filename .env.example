# =============================================================================
# Machine-specific configuration for Qwen Image API
#
# HOW TO USE:
#   cp .env.example .env
#   edit .env  ← fill in the values for THIS machine
#
# .env is intentionally NOT committed to git (see .gitignore).
# .env.example IS committed as documentation.
# =============================================================================

# Absolute path to the HuggingFace model cache directory on this machine.
# Models will be downloaded here and reused across container restarts.
#
# Examples:
#   /pegaai/model_team/huggingface_cache     ← original server
#   /data/hf_cache
#   /home/ubuntu/.cache/huggingface
HF_CACHE_HOST_PATH=/pegaai/model_team/huggingface_cache

# Which GPU to use (run `nvidia-smi` to check available indices)
GPU_DEVICE_ID=0
